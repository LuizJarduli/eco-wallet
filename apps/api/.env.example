# Supabase (cloud) — from Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Server
PORT=3001

# Optional: vision confidence scoring (omit both to use heuristic scorer in local dev)
# VISION_API_URL=https://your-vision-provider.example/score
# VISION_API_KEY=your-vision-api-key

# Optional: rejection push
# FCM_SERVER_KEY=
